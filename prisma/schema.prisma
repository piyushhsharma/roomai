generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ——— NextAuth + app user ———

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  password       String?
  plan           String    @default("free")
  credits        Int       @default(10)
  notifyEmail    Boolean   @default(true)
  notifyProduct  Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  projects        Project[]
  designs         Design[]
  uploadedImages  UploadedImage[]
  inspirations    Inspiration[]
  activityLogs    ActivityLog[]
  subscription    Subscription?

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ——— SaaS domain ———

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  thumbnailUrl String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  designs     Design[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([userId, updatedAt])
}

model UploadedImage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  url       String   @db.Text
  name      String?
  mimeType  String?
  size      Int?
  createdAt DateTime @default(now())

  designs Design[]

  @@index([userId])
}

model Design {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId       String?
  project         Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  uploadedImageId String?
  uploadedImage   UploadedImage? @relation(fields: [uploadedImageId], references: [id], onDelete: SetNull)
  prompt          String?  @db.Text
  style           String?
  roomType        String?
  palette         Json?
  resultUrl       String   @db.Text
  status          String   @default("complete")
  isMock          Boolean  @default(false)
  durationMs      Int?
  inspirations    Inspiration[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([userId, createdAt])
  @@index([projectId])
}

model Inspiration {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  designId  String?
  design    Design?  @relation(fields: [designId], references: [id], onDelete: SetNull)
  title     String?
  imageUrl  String   @db.Text
  notes     String?  @db.Text
  createdAt DateTime @default(now())

  @@index([userId])
}

model Subscription {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                 String   @default("free")
  dailyGenerationsUsed Int      @default(0)
  lastUsageReset       DateTime @default(now())
  dailyCap             Int      @default(10)
  monthlyCap           Int      @default(50)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  message   String
  meta      Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}
